{
  "name": "video-gen",
  "version": "1.0.0",
  "description": "Remotion-based video generation pipeline with Korean TTS",
  "type": "module",
  "scripts": {
    "studio": "remotion studio",
    "render": "NODE_OPTIONS='--max-old-space-size=4096' remotion render VideoComposition",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' remotion render VideoComposition out/video.mp4",
    "render:part": "NODE_OPTIONS='--max-old-space-size=4096' node scripts/render-parts.mjs",
    "render:all": "NODE_OPTIONS='--max-old-space-size=4096' bash scripts/render-all-parts.sh",
    "validate": "tsx scripts/validate-config.ts",
    "tts": "python3 scripts/generate-tts.py",
    "generate": "bash scripts/build-video.sh"
  },
  "dependencies": {
    "@remotion/animation-utils": "^4.0.435",
    "@remotion/cli": "4.0.261",
    "@remotion/layout-utils": "^4.0.435",
    "@remotion/player": "4.0.261",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "4.0.261",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@remotion/bundler": "4.0.261",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
