# yt-dub skill — environment variables
# 외부 유료 API 키 0개. .env 없이도 동작.

# ─── 출력 디렉터리 ──────────────────────────────────────────────────────────
# 미설정 시 ~/yt-dub-projects/<video_id>/
# YT_DUB_PROJECTS_DIR=/path/to/projects

# ─── faster-whisper STT ────────────────────────────────────────────────────
FW_MODEL=large-v3           # tiny | base | small | medium | large-v2 | large-v3 | large-v3-turbo
FW_DEVICE=cuda              # cuda | cpu | auto
FW_COMPUTE_TYPE=float16     # float16(cuda) | int8_float16 | int8(cpu)
FW_VAD=true                 # silero VAD 사용 여부

# ─── 번역 ────────────────────────────────────────────────────────────────
# codex | gemini | claude — codex 기본 (Codex OAuth, 키 불필요)
TRANSLATE_ENGINE=codex
TRANSLATE_TARGET_LANG=ko

# ─── fish-tts ─────────────────────────────────────────────────────────────
FISH_TTS_URL=http://blade-4090:9999
FISH_TTS_VOICE_FEMALE=cwon
FISH_TTS_VOICE_MALE=elon
FISH_TTS_TIMEOUT=180

# ─── 화자 피치 분석 ───────────────────────────────────────────────────────
PITCH_BOUNDARY_HZ=165       # 이 값 미만 → male/elon, 이상 → female/cwon
PITCH_FMIN=80
PITCH_FMAX=400

# ─── 타이밍 ───────────────────────────────────────────────────────────────
ATEMPO_MAX=1.6              # 한국어 1.6배 이상 듣기 거북
ATEMPO_MIN=1.0              # 절대 느리게 하지 않음 (mouth-cue 보존)
TRAIL_MS=120                # utt 끝 호흡 여백

# ─── yt-dlp ──────────────────────────────────────────────────────────────
YTDLP_BIN=
# 비워두면 PATH 에서 자동 탐색
