+def _whisper_to_scribe(result: dict, model_name: str) -> dict:
+    """Re-shape Whisper's result dict into Scribe-compatible JSON.
+
+    Scribe schema consumed downstream:
+      {
+        "words": [
+          {"type": "word",    "text": "Hello", "start": 0.0, "end": 0.5, "speaker_id": "speaker_0"},
+          {"type": "spacing", "text": " ",     "start": 0.5, "end": 0.6},
+          ...
+        ],
+        "language_code": "en",
+        "text": "full text",
+      }
+
+    We emit synthetic `spacing` entries for any gap > 0s so pack_transcripts.py's
+    silence-based phrase breaking keeps working.
+    """
+    items: list[dict] = []
+    prev_end: float | None = None
+    full_text_parts: list[str] = []
+
+    for seg in result.get("segments", []) or []:
+        for w in seg.get("words", []) or []:
+            # Whisper returns {"word": " Hello", "start": 0.0, "end": 0.5, "probability": ...}
+            raw = (w.get("word") or "").strip()
+            if not raw:
+                continue
+            start = w.get("start")
+            end = w.get("end")
+            if start is None or end is None:
+                continue
+            start = float(start)
+            end = float(end)
+            if prev_end is not None and start > prev_end:
+                items.append({
+                    "type": "spacing",
+                    "text": " ",
+                    "start": prev_end,
+                    "end": start,
+                })
+            items.append({
+                "type": "word",
+                "text": raw,
+                "start": start,
+                "end": end,
+                "speaker_id": "speaker_0",
+            })
+            full_text_parts.append(raw)
+            prev_end = end
+
+    return {
+        "words": items,
+        "language_code": result.get("language", ""),
+        "text": " ".join(full_text_parts),
+        "model": f"whisper-{model_name}",
+    }
+
