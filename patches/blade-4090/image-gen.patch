+def _fmt_seconds(s: int) -> str:
+    if s <= 0:
+        return "0s"
+    d, rem = divmod(s, 86400)
+    h, rem = divmod(rem, 3600)
+    m, _ = divmod(rem, 60)
+    if d:
+        return f"{d}d{h}h"
+    if h:
+        return f"{h}h{m}m"
+    return f"{m}m"
+
+
+def format_quota_line(h: dict) -> str | None:
+    """Build a one-line quota summary from x-codex-* response headers."""
+    if "x-codex-plan-type" not in h and "x-codex-primary-used-percent" not in h:
+        return None
+    plan = h.get("x-codex-plan-type", "?").upper()
+    bits = [f"[Codex {plan}]"]
+
+    try:
+        p_pct = float(h.get("x-codex-primary-used-percent", "0"))
+        p_win = int(h.get("x-codex-primary-window-minutes", "0"))
+        p_reset = int(h.get("x-codex-primary-reset-after-seconds", "0"))
+        p_label = f"{p_win // 60}h" if p_win % 60 == 0 else f"{p_win}m"
+        warn = " ⚠" if p_pct >= 80 else ""
+        bits.append(f"{p_label}: {p_pct:g}%{warn} (resets in {_fmt_seconds(p_reset)})")
+    except (TypeError, ValueError):
+        pass
+
+    try:
+        s_pct = float(h.get("x-codex-secondary-used-percent", "0"))
+        s_win = int(h.get("x-codex-secondary-window-minutes", "0"))
+        s_reset = int(h.get("x-codex-secondary-reset-after-seconds", "0"))
+        s_label = f"{s_win // 1440}d" if s_win % 1440 == 0 else f"{s_win // 60}h"
+        warn = " ⚠" if s_pct >= 80 else ""
+        bits.append(f"{s_label}: {s_pct:g}%{warn} (resets in {_fmt_seconds(s_reset)})")
+    except (TypeError, ValueError):
+        pass
+
+    if h.get("x-codex-credits-unlimited", "").lower() == "true":
+        bits.append("credits: unlimited")
+    elif h.get("x-codex-credits-has-credits", "").lower() == "true":
+        bal = h.get("x-codex-credits-balance", "").strip()
+        bits.append(f"credits: {bal or 'available'}")
+
+    return " | ".join(bits)
+
