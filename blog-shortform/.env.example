# blog-shortform skill — environment variables
# 이 fork 는 외부 API 키가 필요 없다. .env 없이도 동작.
# 필요하면 이 파일을 `.env` 로 복사한 뒤 옵션 값만 조정.
#   cp .env.example .env

# ─── fish-tts (Phase 2 TTS) ─────────────────────────────────────────────────
# 로컬 soma-voice HTTP 서비스. blade-4090 에서 systemd user 로 동작.
# API 키 불필요. 서비스가 꺼져 있으면:
#   ssh blade-4090 systemctl --user start ai.2lab.soma-voice.main.service
FISH_TTS_URL=http://blade-4090:9999
FISH_TTS_VOICE_A=cwon        # 화자 A (여성, 30대 리드)
FISH_TTS_VOICE_B=elon        # 화자 B (남성, 20대 리액션)
FISH_TTS_TIMEOUT=180

# ─── image-gen (Phase 2 이미지) ─────────────────────────────────────────────
# ~/2lab.ai/skills/image-gen/scripts/gen_image.py 에 위임.
# Codex/ChatGPT OAuth 세션 사용 — API 키 불필요.
# 다른 위치에 image-gen 이 있다면 경로 오버라이드:
# IMAGE_GEN_SCRIPT=/custom/path/to/gen_image.py
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=high

# ─── 프로젝트 경로 (선택) ────────────────────────────────────────────────────
# 미설정 시 ~/blog-shortform-projects 사용
# BLOG_SHORTFORM_PROJECTS_DIR=/path/to/projects
